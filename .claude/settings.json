{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(fvm flutter analyze:*)",
      "Bash(fvm flutter test:*)",
      "Bash(fvm flutter pub get:*)",
      "Bash(fvm flutter pub outdated:*)",
      "Bash(fvm flutter pub deps:*)",
      "Bash(fvm dart format:*)",
      "Bash(fvm dart analyze:*)",
      "Bash(fvm dart fix:*)",
      "Bash(fvm dart run build_runner:*)",
      "Bash(make get:*)",
      "Bash(make gen:*)",
      "Bash(make format:*)",
      "Bash(make build_runner:*)",
      "Bash(make fcg:*)",
      "Bash(make analyze:*)",
      "Bash(make help:*)",
      "Bash(make test:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --ff-only:*)"
    ],
    "deny": [
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push upstream main:*)",
      "Bash(git push upstream master:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/gate_git_push.sh" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/block_generated_files.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format_dart.sh"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          { "type": "command", "command": "jq -c . >> .claude/logs/denied.jsonl" }
        ]
      }
    ]
  }
}
